<div class="page-header">
  <div class="page-header-left">
    <h1>My Dashboard</h1>
    <p>Welcome, <%= currentUser.fullName %>! Here's your case overview.</p>
  </div>
</div>

<!-- Stats -->
<div class="stats-grid">
  <div class="stat-card purple">
    <div class="stat-icon purple"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 20h16a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.93a2 2 0 0 1-1.66-.9l-.82-1.2A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13c0 1.1.9 2 2 2Z"/></svg></div>
    <div class="stat-info">
      <div class="stat-value"><%= stats.totalCases %></div>
      <div class="stat-label">My Cases</div>
    </div>
  </div>
  <div class="stat-card teal">
    <div class="stat-icon teal"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 9.9-1"/></svg></div>
    <div class="stat-info">
      <div class="stat-value"><%= stats.openCases %></div>
      <div class="stat-label">Active Cases</div>
    </div>
  </div>
  <div class="stat-card amber">
    <div class="stat-icon amber"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></div>
    <div class="stat-info">
      <div class="stat-value"><%= stats.upcomingDeadlines %></div>
      <div class="stat-label">Upcoming Deadlines</div>
    </div>
  </div>
</div>

<!-- My Cases -->
<div class="card">
  <div class="card-header">
    <h3 class="card-title">My Cases</h3>
  </div>
  <% if (cases.length > 0) { %>
    <div class="table-wrapper" style="border: none;">
      <table class="table">
        <thead>
          <tr>
            <th>Case</th>
            <th>Type</th>
            <th>Status</th>
            <th>Attorney</th>
            <th>Deadline</th>
          </tr>
        </thead>
        <tbody>
          <% cases.forEach(function(c) { %>
            <tr>
              <td>
                <a href="/cases/<%= c.id %>" class="table-title" style="color: var(--brand-primary);"><%= c.title %></a>
              </td>
              <td><span class="badge badge-<%= c.type %>"><%= c.type %></span></td>
              <td><span class="badge badge-<%= c.status %>"><%= c.status.replace('_', ' ') %></span></td>
              <td class="text-sm"><%= c.attorney ? c.attorney.full_name : '—' %></td>
              <td>
                <% if (c.deadline) { %>
                  <div class="deadline-indicator <%= c.daysLeft <= 7 ? 'critical' : c.daysLeft <= 14 ? 'warning' : c.daysLeft <= 30 ? 'upcoming' : 'normal' %>">
                    <span class="deadline-dot"></span>
                    <%= c.daysLeft %> days
                  </div>
                <% } else { %>
                  <span class="text-sm text-muted">—</span>
                <% } %>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  <% } else { %>
    <div class="empty-state">
      <div class="empty-state-icon"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 20h16a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.93a2 2 0 0 1-1.66-.9l-.82-1.2A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13c0 1.1.9 2 2 2Z"/></svg></div>
      <p class="empty-state-title">No cases assigned</p>
      <p class="empty-state-desc">You'll see your cases here once your attorney assigns them.</p>
    </div>
  <% } %>
</div>

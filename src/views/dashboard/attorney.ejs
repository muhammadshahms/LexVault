<div class="page-header">
  <div class="page-header-left">
    <h1>Attorney Dashboard</h1>
    <p>Welcome back, <%= currentUser.fullName %>!</p>
  </div>
  <a href="/cases/create" class="btn btn-primary">+ New Case</a>
</div>

<!-- Stats -->
<div class="stats-grid">
  <div class="stat-card purple">
    <div class="stat-icon purple"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 20h16a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.93a2 2 0 0 1-1.66-.9l-.82-1.2A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13c0 1.1.9 2 2 2Z"/></svg></div>
    <div class="stat-info">
      <div class="stat-value"><%= stats.myCases %></div>
      <div class="stat-label">My Cases</div>
    </div>
  </div>
  <div class="stat-card teal">
    <div class="stat-icon teal"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 9.9-1"/></svg></div>
    <div class="stat-info">
      <div class="stat-value"><%= stats.openCases %></div>
      <div class="stat-label">Open Cases</div>
    </div>
  </div>
  <div class="stat-card amber">
    <div class="stat-icon amber"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg></div>
    <div class="stat-info">
      <div class="stat-value"><%= stats.activeClients %></div>
      <div class="stat-label">Active Clients</div>
    </div>
  </div>
</div>

<!-- Two-column layout -->
<div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
  <!-- Recent Cases -->
  <div class="card">
    <div class="card-header">
      <h3 class="card-title">Recent Cases</h3>
      <a href="/cases" class="btn btn-ghost btn-sm">View all →</a>
    </div>
    <% if (recentCases.length > 0) { %>
      <div style="display: flex; flex-direction: column; gap: 10px;">
        <% recentCases.forEach(function(c) { %>
          <a href="/cases/<%= c.id %>" style="display: flex; align-items: center; justify-content: space-between; padding: 12px 14px; background: var(--gray-50); border-radius: var(--border-radius-md); text-decoration: none; transition: all 0.15s;">
            <div>
              <div style="font-size: 13px; font-weight: 500; color: var(--gray-900);"><%= c.title %></div>
              <div style="font-size: 11px; color: var(--gray-400); margin-top: 2px;"><%= c.client ? c.client.full_name : 'No client' %></div>
            </div>
            <div style="display: flex; gap: 6px;">
              <span class="badge badge-<%= c.type %>"><%= c.type %></span>
              <span class="badge badge-<%= c.status %>"><%= c.status.replace('_', ' ') %></span>
            </div>
          </a>
        <% }); %>
      </div>
    <% } else { %>
      <div class="empty-state" style="padding: 30px;">
        <div class="empty-state-icon"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 20h16a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.93a2 2 0 0 1-1.66-.9l-.82-1.2A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13c0 1.1.9 2 2 2Z"/></svg></div>
        <p class="empty-state-title">No cases yet</p>
        <a href="/cases/create" class="btn btn-primary btn-sm">+ Create Case</a>
      </div>
    <% } %>
  </div>

  <!-- Upcoming Deadlines -->
  <div class="card">
    <div class="card-header">
      <h3 class="card-title">Upcoming Deadlines</h3>
      <a href="/deadlines" class="btn btn-ghost btn-sm">View all →</a>
    </div>
    <% if (deadlines.length > 0) { %>
      <div style="display: flex; flex-direction: column; gap: 10px;">
        <% deadlines.forEach(function(d) { %>
          <div style="display: flex; align-items: center; gap: 12px; padding: 12px 14px; border-radius: var(--border-radius-md); border-left: 3px solid <%= d.daysLeft <= 7 ? 'var(--danger)' : 'var(--warning)' %>; background: <%= d.daysLeft <= 7 ? 'var(--danger-bg)' : 'var(--warning-bg)' %>;">
            <div style="font-weight: 700; font-size: 20px; min-width: 40px; color: <%= d.daysLeft <= 7 ? 'var(--danger)' : 'var(--warning)' %>;">
              <%= d.daysLeft %>
              <div style="font-size: 9px; font-weight: 500; text-transform: uppercase; opacity: 0.7;">days</div>
            </div>
            <div style="flex: 1;">
              <a href="/cases/<%= d.id %>" style="font-size: 13px; font-weight: 500; color: var(--gray-900); text-decoration: none;"><%= d.title %></a>
              <div style="font-size: 11px; color: var(--gray-400);"><%= new Date(d.deadline).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></div>
            </div>
          </div>
        <% }); %>
      </div>
    <% } else { %>
      <div class="empty-state" style="padding: 30px;">
        <div class="empty-state-icon"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg></div>
        <p class="empty-state-title">No urgent deadlines</p>
        <p class="empty-state-desc text-sm text-muted">All deadlines are more than 14 days away</p>
      </div>
    <% } %>
  </div>
</div>

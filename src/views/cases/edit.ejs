<div class="page-header">
  <div class="page-header-left">
    <h1>Edit Case</h1>
    <p>Update case information</p>
  </div>
  <a href="/cases/<%= caseData.id %>" class="btn btn-secondary">← Back to Case</a>
</div>

<div class="card" style="max-width: 720px;">
  <form action="/cases/<%= caseData.id %>?_method=PUT" method="POST">
    <div class="form-group">
      <label class="form-label" for="title">Case Title *</label>
      <input type="text" id="title" name="title" class="form-input" value="<%= caseData.title %>" required>
    </div>

    <div class="form-row">
      <div class="form-group">
        <label class="form-label" for="type">Case Type *</label>
        <select id="type" name="type" class="form-select" required>
          <option value="trademark" <%= caseData.type === 'trademark' ? 'selected' : '' %>>Trademark</option>
          <option value="patent" <%= caseData.type === 'patent' ? 'selected' : '' %>>Patent</option>
          <option value="copyright" <%= caseData.type === 'copyright' ? 'selected' : '' %>>Copyright</option>
          <option value="trade_secret" <%= caseData.type === 'trade_secret' ? 'selected' : '' %>>Trade Secret</option>
        </select>
      </div>
      <div class="form-group">
        <label class="form-label" for="status">Status *</label>
        <select id="status" name="status" class="form-select" required>
          <option value="open" <%= caseData.status === 'open' ? 'selected' : '' %>>Open</option>
          <option value="in_progress" <%= caseData.status === 'in_progress' ? 'selected' : '' %>>In Progress</option>
          <option value="under_review" <%= caseData.status === 'under_review' ? 'selected' : '' %>>Under Review</option>
          <option value="closed" <%= caseData.status === 'closed' ? 'selected' : '' %>>Closed</option>
        </select>
      </div>
    </div>

    <div class="form-row">
      <div class="form-group">
        <label class="form-label" for="client_id">Assign Client</label>
        <select id="client_id" name="client_id" class="form-select">
          <option value="">No client</option>
          <% clients.forEach(function(c) { %>
            <option value="<%= c.id %>" <%= caseData.client_id === c.id ? 'selected' : '' %>><%= c.full_name %></option>
          <% }); %>
        </select>
      </div>
      <% if (currentUser.role === 'admin') { %>
        <div class="form-group">
          <label class="form-label" for="attorney_id">Assign Attorney</label>
          <select id="attorney_id" name="attorney_id" class="form-select">
            <option value="">Select attorney...</option>
            <% attorneys.forEach(function(a) { %>
              <option value="<%= a.id %>" <%= caseData.attorney_id === a.id ? 'selected' : '' %>><%= a.full_name %></option>
            <% }); %>
          </select>
        </div>
      <% } %>
    </div>

    <div class="form-group">
      <label class="form-label" for="description">Description</label>
      <textarea id="description" name="description" class="form-textarea"><%= caseData.description || '' %></textarea>
    </div>

    <div class="form-row">
      <div class="form-group">
        <label class="form-label" for="filing_date">Filing Date</label>
        <input type="date" id="filing_date" name="filing_date" class="form-input" value="<%= caseData.filing_date || '' %>">
      </div>
      <div class="form-group">
        <label class="form-label" for="deadline">Deadline</label>
        <input type="date" id="deadline" name="deadline" class="form-input" value="<%= caseData.deadline || '' %>">
      </div>
    </div>

    <div style="display: flex; gap: 12px; margin-top: 8px;">
      <button type="submit" class="btn btn-primary">Save Changes</button>
      <a href="/cases/<%= caseData.id %>" class="btn btn-secondary">Cancel</a>
    </div>
  </form>
</div>

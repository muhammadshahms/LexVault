<div class="page-header">
  <div class="page-header-left">
    <h1>Cases</h1>
    <p>Manage your intellectual property cases</p>
  </div>
  <% if (currentUser.role === 'admin' || currentUser.role === 'attorney') { %>
    <a href="/cases/create" class="btn btn-primary">+ New Case</a>
  <% } %>
</div>

<!-- Filter Bar -->
<form action="/cases" method="GET" class="filter-bar">
  <div class="search-input-wrapper">
    <span class="search-icon"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg></span>
    <input type="text" name="search" class="form-input" placeholder="Search cases..." value="<%= search %>">
  </div>
  <select name="status" class="form-select filter-select">
    <option value="">All Statuses</option>
    <option value="open" <%= statusFilter === 'open' ? 'selected' : '' %>>Open</option>
    <option value="in_progress" <%= statusFilter === 'in_progress' ? 'selected' : '' %>>In Progress</option>
    <option value="under_review" <%= statusFilter === 'under_review' ? 'selected' : '' %>>Under Review</option>
    <option value="closed" <%= statusFilter === 'closed' ? 'selected' : '' %>>Closed</option>
  </select>
  <select name="type" class="form-select filter-select">
    <option value="">All Types</option>
    <option value="trademark" <%= typeFilter === 'trademark' ? 'selected' : '' %>>Trademark</option>
    <option value="patent" <%= typeFilter === 'patent' ? 'selected' : '' %>>Patent</option>
    <option value="copyright" <%= typeFilter === 'copyright' ? 'selected' : '' %>>Copyright</option>
    <option value="trade_secret" <%= typeFilter === 'trade_secret' ? 'selected' : '' %>>Trade Secret</option>
  </select>
  <button type="submit" class="btn btn-secondary">Filter</button>
</form>

<!-- Cases Table -->
<% if (cases.length > 0) { %>
  <div class="table-wrapper">
    <table class="table">
      <thead>
        <tr>
          <th>Case Title</th>
          <th>Type</th>
          <th>Status</th>
          <% if (currentUser.role === 'admin') { %>
            <th>Attorney</th>
          <% } %>
          <th>Client</th>
          <th>Deadline</th>
          <th>Filed</th>
          <% if (currentUser.role !== 'client') { %>
            <th></th>
          <% } %>
        </tr>
      </thead>
      <tbody>
        <% cases.forEach(function(c) { %>
          <tr>
            <td>
              <a href="/cases/<%= c.id %>" class="table-title" style="color: var(--brand-primary); font-weight: 500;"><%= c.title %></a>
            </td>
            <td><span class="badge badge-<%= c.type %>"><%= c.type.replace('_', ' ') %></span></td>
            <td><span class="badge badge-<%= c.status %>"><%= c.status.replace('_', ' ') %></span></td>
            <% if (currentUser.role === 'admin') { %>
              <td class="text-sm"><%= c.attorney ? c.attorney.full_name : '—' %></td>
            <% } %>
            <td class="text-sm"><%= c.client ? c.client.full_name : '—' %></td>
            <td>
              <% if (c.daysLeft !== null) { %>
                <div class="deadline-indicator <%= c.daysLeft <= 7 ? 'critical' : c.daysLeft <= 14 ? 'warning' : c.daysLeft <= 30 ? 'upcoming' : 'normal' %>">
                  <span class="deadline-dot"></span>
                  <%= c.daysLeft %> days
                </div>
              <% } else { %>
                <span class="text-sm text-muted">—</span>
              <% } %>
            </td>
            <td class="text-sm text-muted"><%= c.filing_date ? new Date(c.filing_date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : '—' %></td>
            <% if (currentUser.role !== 'client') { %>
              <td>
                <div style="display: flex; gap: 4px;">
                  <a href="/cases/<%= c.id %>/edit" class="btn btn-ghost btn-sm" title="Edit"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/><path d="m15 5 4 4"/></svg></a>
                  <form action="/cases/<%= c.id %>?_method=DELETE" method="POST" style="margin: 0;">
                    <button type="submit" class="btn btn-ghost btn-sm" title="Delete" data-confirm="Are you sure you want to delete this case?" style="color: var(--danger);"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg></button>
                  </form>
                </div>
              </td>
            <% } %>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
<% } else { %>
  <div class="card">
    <div class="empty-state">
      <div class="empty-state-icon"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 20h16a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.93a2 2 0 0 1-1.66-.9l-.82-1.2A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13c0 1.1.9 2 2 2Z"/></svg></div>
      <p class="empty-state-title">No cases found</p>
      <p class="empty-state-desc">
        <% if (search || statusFilter || typeFilter) { %>
          Try adjusting your filters
        <% } else { %>
          Create your first IP case to get started
        <% } %>
      </p>
      <% if (currentUser.role !== 'client') { %>
        <a href="/cases/create" class="btn btn-primary btn-sm">+ Create Case</a>
      <% } %>
    </div>
  </div>
<% } %>

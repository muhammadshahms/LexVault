<header class="navbar">
  <div class="navbar-left">
    <button id="mobile-menu-btn" class="mobile-menu-btn" aria-label="Toggle menu">☰</button>
    <h2 class="navbar-title"><%= typeof title !== 'undefined' ? title : 'Dashboard' %></h2>
  </div>

<div class="page-header">
  <div class="page-header-left">
    <h1>Clients</h1>
    <p>Manage your client relationships</p>
  </div>
</div>

<% if (clients.length > 0) { %>
  <div class="client-grid">
    <% clients.forEach(function(c) { %>
      <div class="client-card">
        <div class="client-avatar">
          <%= c.full_name ? c.full_name.charAt(0).toUpperCase() : '?' %>
        </div>
        <div class="client-info" style="flex: 1; min-width: 0;">
          <div class="client-info-name"><%= c.full_name %></div>
          <div class="client-info-meta">
            <%= c.caseCount %> case<%= c.caseCount !== 1 ? 's' : '' %>
            <% if (c.firm_name) { %> · <%= c.firm_name %><% } %>
          </div>
        </div>
        <span class="badge badge-client">Client</span>
      </div>
    <% }); %>
  </div>
<% } else { %>
  <div class="card">
    <div class="empty-state">
      <div class="empty-state-icon">👥</div>
      <p class="empty-state-title">No clients yet</p>
      <p class="empty-state-desc">Clients will appear here once they register and are assigned to your cases.</p>
    </div>
  </div>
<% } %>

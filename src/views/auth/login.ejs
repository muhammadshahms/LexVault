<div class="auth-layout">
  <div class="auth-brand">
    <div class="auth-brand-content">
      <div class="auth-brand-logo"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 16l3-8 3 8c-.87.65-1.92 1-3 1s-2.13-.35-3-1Z"/><path d="M2 16l3-8 3 8c-.87.65-1.92 1-3 1s-2.13-.35-3-1Z"/><path d="M7 21h10"/><path d="M12 3v18"/><path d="M3 7h2c2 0 5-1 7-2 2 1 5 2 7 2h2"/></svg></div>
      <h1 class="auth-brand-title">LexVault</h1>
      <p class="auth-brand-desc">The premier platform for managing intellectual property cases, deadlines, and client relationships.</p>
      <div class="auth-brand-features">
        <div class="auth-brand-feature">
          <div class="auth-brand-feature-icon"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 20h16a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.93a2 2 0 0 1-1.66-.9l-.82-1.2A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13c0 1.1.9 2 2 2Z"/></svg></div>
          <span>Manage trademark, patent & copyright cases</span>
        </div>
        <div class="auth-brand-feature">
          <div class="auth-brand-feature-icon"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></div>
          <span>Automated deadline alerts & tracking</span>
        </div>
        <div class="auth-brand-feature">
          <div class="auth-brand-feature-icon"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg></div>
          <span>Role-based access for attorneys & clients</span>
        </div>
        <div class="auth-brand-feature">
          <div class="auth-brand-feature-icon"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="5" rx="2"/><line x1="2" x2="22" y1="10" y2="10"/></svg></div>
          <span>Integrated billing & subscription plans</span>
        </div>
      </div>
    </div>
  </div>

  <div class="auth-form-side">
    <div class="auth-form-container">
      <h2 class="auth-form-title">Welcome back</h2>
      <p class="auth-form-subtitle">Sign in to your LexVault account</p>

      <% if (typeof error !== 'undefined' && error && error.length > 0) { %>
        <% error.forEach(function(msg) { %>
          <div class="alert alert-error">
            <span><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6"/><path d="m9 9 6 6"/></svg></span>
            <span><%= msg %></span>
          </div>
        <% }); %>
      <% } %>

      <% if (typeof success !== 'undefined' && success && success.length > 0) { %>
        <% success.forEach(function(msg) { %>
          <div class="alert alert-success">
            <span><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg></span>
            <span><%= msg %></span>
          </div>
        <% }); %>
      <% } %>

      <div class="auth-form">
        <form action="/auth/login" method="POST">
          <div class="form-group">
            <label class="form-label" for="email">Email address</label>
            <input type="email" id="email" name="email" class="form-input" placeholder="you@example.com" required autofocus>
          </div>

          <div class="form-group">
            <label class="form-label" for="password">Password</label>
            <input type="password" id="password" name="password" class="form-input" placeholder="Enter your password" required>
          </div>

          <button type="submit" class="btn btn-primary">Sign in</button>
        </form>
      </div>

      <div class="auth-form-footer">
        Don't have an account? <a href="/auth/register">Create one</a>
      </div>
    </div>
  </div>
</div>
